.sports-page {
  width: 100vw;
  height: 100vh;
  position: relative;
  background: #1a1a2e;
}

.map-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.player-canvas {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
}

.back-btn {
  position: absolute;
  top: 60px;
  left: 20px;
  padding: 10px 20px;
  background: rgba(26, 26, 46, 0.8);
  color: #f4a261;
  z-index: 100;
}

.game-time {
  position: absolute;
  top: 60px;
  right: 20px;
  padding: 10px 20px;
  background: rgba(26, 26, 46, 0.8);
  color: #f4a261;
  font-size: 16px;
  z-index: 100;
}

/* 浮动摇杆(跟随触摸位置,不拦截事件) */
.joystick-area {
  position: absolute;
  z-index: 20;
  pointer-events: none;
  transform: translate(-50%, -50%);
}

.joystick-base {
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%,
    rgba(244,162,97,0.25) 0%,
    rgba(244,162,97,0.08) 60%,
    rgba(244,162,97,0.02) 100%
  );
  border: 3rpx solid rgba(244,162,97,0.5);
  position: relative;
  box-shadow:
    inset 0 0 24rpx rgba(0,0,0,0.3),
    0 0 16rpx rgba(244,162,97,0.1);
}

.joystick-stick {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%,
    rgba(244,162,97,0.95) 0%,
    rgba(244,162,97,0.7) 100%
  );
  border: 3rpx solid #f4a261;
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -22rpx;
  margin-top: -22rpx;
  transition: none;
  box-shadow:
    0 2rpx 6rpx rgba(0,0,0,0.4),
    inset 0 2rpx 3rpx rgba(255,255,255,0.2);
}