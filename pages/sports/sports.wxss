.sports-page {
  width: 100vw;
  height: 100vh;
  position: relative;
  background: #1a1a2e;
}

.map-bg {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.player-canvas {
  width: 100vw;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 10;
}

.back-btn {
  position: absolute;
  top: 60px;
  left: 20px;
  padding: 10px 20px;
  background: rgba(26, 26, 46, 0.8);
  color: #f4a261;
  z-index: 100;
}