.sports-page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #0f0f1a;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.bg-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #0f0f1a;
}

.placeholder-text {
  font-size: 28rpx;
  color: #f4a261;
}

.placeholder-hint {
  font-size: 20rpx;
  color: #666;
  margin-top: 16rpx;
}

.back-btn {
  position: absolute;
  top: calc(20rpx + var(--status-bar-height, 44px));
  left: 20rpx;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(26, 26, 46, 0.8);
  border: 2rpx solid #f4a261;
  border-radius: 12rpx;
  z-index: 100;
}

.back-arrow {
  font-size: 32rpx;
  color: #f4a261;
  margin-right: 8rpx;
}

.back-text {
  font-size: 22rpx;
  color: #f4a261;
  font-weight: bold;
}