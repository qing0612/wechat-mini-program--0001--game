.backpack-page {
  min-height: 100vh;
  background: #0f0f1a;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon .arrow {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 16rpx solid #8bc34a;
}

.nav-title {
  font-size: 32rpx;
  color: #8bc34a;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.nav-placeholder {
  width: 64rpx;
}

/* 背包内容 */
.backpack-content {
  padding: 40rpx 30rpx;
}

/* 物品网格 */
.items-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.item-slot {
  aspect-ratio: 1;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(139, 195, 74, 0.3);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.item-slot:active {
  border-color: #8bc34a;
  background: rgba(139, 195, 74, 0.1);
}

.item-icon {
  width: 80%;
  height: 80%;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.3);
}

.item-count {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #f4a261;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.item-slot-empty {
  width: 80%;
  height: 80%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 40%;
  height: 40%;
  border: 2rpx dashed rgba(139, 195, 74, 0.3);
  border-radius: 8rpx;
}

/* 物品详情 */
.item-detail {
  margin-top: 40rpx;
  background: rgba(26, 26, 46, 0.6);
  border: 2rpx solid rgba(139, 195, 74, 0.3);
  border-radius: 16rpx;
  padding: 30rpx;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.detail-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.detail-info {
  flex: 1;
}

.detail-name {
  font-size: 32rpx;
  color: #8bc34a;
  font-weight: 600;
  display: block;
}

.detail-count {
  font-size: 24rpx;
  color: rgba(139, 195, 74, 0.6);
  margin-top: 8rpx;
  display: block;
}

.detail-desc {
  font-size: 26rpx;
  color: #ccc;
  line-height: 1.6;
  display: block;
  margin-bottom: 24rpx;
}

.detail-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 500;
}

.use-btn {
  background: linear-gradient(135deg, #8bc34a 0%, #689f38 100%);
  color: #fff;
}

.drop-btn {
  background: linear-gradient(135deg, #e53935 0%, #c62828 100%);
  color: #fff;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}