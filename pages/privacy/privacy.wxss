.privacy-page {
  min-height: 100vh;
  background: #0f0f1a;
}

/* 导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon .arrow {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 16rpx solid #f4a261;
}

.nav-title {
  font-size: 32rpx;
  color: #f4a261;
  font-weight: 600;
  letter-spacing: 4rpx;
}

.nav-placeholder {
  width: 64rpx;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  margin: 20rpx 30rpx;
  background: rgba(26, 26, 46, 0.6);
  border-radius: 16rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(244, 162, 97, 0.2);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-item.tab-active {
  background: rgba(244, 162, 97, 0.2);
}

.tab-text {
  font-size: 26rpx;
  color: #ccc;
}

.tab-item.tab-active .tab-text {
  color: #f4a261;
  font-weight: 600;
}

/* 内容滚动区 */
.content-scroll {
  height: calc(100vh - 260rpx);
}

.content-wrap {
  padding: 30rpx 40rpx 80rpx;
}

/* 文档标题 */
.doc-title {
  font-size: 34rpx;
  color: #f4a261;
  font-weight: 700;
  text-align: center;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.doc-update {
  font-size: 22rpx;
  color: rgba(244, 162, 97, 0.5);
  text-align: center;
  margin-bottom: 40rpx;
}

/* 章节标题 */
.section-title {
  font-size: 28rpx;
  color: #f4a261;
  font-weight: 700;
  margin-top: 34rpx;
  margin-bottom: 18rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #f4a261;
}

/* 段落 */
.paragraph {
  margin-bottom: 20rpx;
}

.text {
  font-size: 26rpx;
  color: #d9d9d9;
  line-height: 1.9;
  letter-spacing: 1rpx;
}

.strong {
  color: #e0c49b;
  font-weight: 600;
}