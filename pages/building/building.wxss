@import '../../styles/pixel-theme.wxss';

.building-page {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background: #0f0f1a;
}

/* 加载遮罩 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: #0f0f1a;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(244, 162, 97, 0.3);
  border-top-color: #f4a261;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #f4a261;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

/* 全屏背景图 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.bg-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    repeating-linear-gradient(
      0deg, transparent 0, transparent 48rpx,
      rgba(244,162,97,0.03) 48rpx, rgba(244,162,97,0.03) 50rpx
    ),
    repeating-linear-gradient(
      90deg, transparent 0, transparent 48rpx,
      rgba(244,162,97,0.03) 48rpx, rgba(244,162,97,0.03) 50rpx
    ),
    linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #2a2a4a 100%);
}

/* 【修复7】像素风占位框 */
.placeholder-frame {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx;
  border: 4rpx solid #f4a261;
  box-shadow:
    8rpx 0 0 0 #f4a261,
    -8rpx 0 0 0 #f4a261,
    0 8rpx 0 0 #f4a261,
    0 -8rpx 0 0 #f4a261,
    8rpx 8rpx 0 0 #f4a261,
    -8rpx 8rpx 0 0 #f4a261,
    8rpx -8rpx 0 0 #f4a261,
    -8rpx -8rpx 0 0 #f4a261;
  background: rgba(26,26,46,0.9);
}

.placeholder-icon-wrap {
  margin-bottom: 20rpx;
}

/* 像素风建筑图标 */
.pixel-building-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.icon-roof {
  width: 0;
  height: 0;
  border-left: 40rpx solid transparent;
  border-right: 40rpx solid transparent;
  border-bottom: 30rpx solid #f4a261;
}

.icon-body {
  width: 80rpx;
  height: 50rpx;
  background: #2a2a4a;
  border: 3rpx solid #f4a261;
}

.icon-door {
  width: 20rpx;
  height: 24rpx;
  background: #f4a261;
  margin-top: -24rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.placeholder-sub {
  font-size: 20rpx;
  color: #888;
  margin-top: 10rpx;
}

.placeholder-hint {
  font-size: 16rpx;
  color: #555;
  margin-top: 8rpx;
  font-family: monospace;
}

/* 内容叠层 */
.content-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: rgba(15,15,26,0.55);
}

/* ===== 上三分之一：返回键 + 建筑名 ===== */
.header-area {
  flex: 0 0 25%;
  display: flex;
  flex-direction: column;
  border-bottom: 2rpx solid rgba(244,162,97,0.3);
}

.nav-bar {
  padding: 8rpx 14rpx;
  padding-top: calc(4rpx + var(--status-bar-height, 44px));
  flex-shrink: 0;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 8rpx;
  transform: translateY(-4rpx);   /* 返回按钮上移 */
}

.back-arrow {
  font-size: 32rpx;
  color: #f4a261;
  margin-right: 8rpx;
  transform: translateY(-12rpx);  /* 返回箭头上移 */
}

.back-text {
  font-size: 20rpx;
  color: #f4a261;
  font-weight: bold;
  letter-spacing: 2rpx;
  transform: translateY(-10rpx);  /* 返回文字上移 */
}

.title-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-top: -70rpx; /* 上移建筑名称 */
}

.building-name {
  font-size: 32rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 6rpx;
  text-shadow: 2rpx 2rpx 0 #0f0f1a;
}

.building-name-en {
  font-size: 16rpx;
  color: #aaa;
  letter-spacing: 3rpx;
  margin-top: 6rpx;
  text-transform: uppercase;
}

/* ===== 下三分之二：历史文案 ===== */
.history-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.history-scroll {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow: hidden;
}

.history-card {
  background: rgba(26,26,46,0.85);
  border: 3rpx solid #f4a261;
  padding: 28rpx;
  margin: 0 100rpx;  
  box-shadow:
    4rpx 0 0 0 #f4a261,
    -4rpx 0 0 0 #f4a261,
    0 4rpx 0 0 #f4a261,
    0 -4rpx 0 0 #f4a261,
    4rpx 4rpx 0 0 #f4a261,
    -4rpx 4rpx 0 0 #f4a261,
    4rpx -4rpx 0 0 #f4a261,
    -4rpx -4rpx 0 0 #f4a261;
}

.section-title {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}

.history-text {
  font-size: 26rpx;
  color: #ccc;
  line-height: 1.8;
  display: block;
  letter-spacing: 1rpx;
}

/* 底部装饰 */
.bottom-deco {
  text-align: center;
  padding: 10rpx 0;
  padding-bottom: calc(10rpx + env(safe-area-inset-bottom));
  font-size: 16rpx;
  color: rgba(244,162,97,0.3);
  letter-spacing: 3rpx;
  flex-shrink: 0;
}

.badge-popup {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.badge-content {
  background: linear-gradient(180deg, #1a1a2e 0%, #0f0f1a 100%);
  border: 3rpx solid #f4a261;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.5);
}

.badge-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.3);
  animation: badgeBounce 0.6s ease-out;
}

@keyframes badgeBounce {
  0% { transform: scale(0); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.badge-title {
  font-size: 36rpx;
  color: #f4a261;
  font-weight: 600;
  display: block;
  margin-bottom: 16rpx;
}

.badge-name {
  font-size: 32rpx;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.badge-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  display: block;
  margin-bottom: 30rpx;
}

.badge-close {
  background: linear-gradient(135deg, #f4a261 0%, #e67e22 100%);
  color: #fff;
  padding: 16rpx 60rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: inline-block;
}