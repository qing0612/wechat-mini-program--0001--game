@import '../../styles/pixel-theme.wxss';

.map-page {
  width: 100vw;
  height: 100vh;
  background: #0f0f1a;
  position: relative;
  overflow: hidden;
}

.game-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  background: #3D6B24;
}

/* 浮动摇杆(跟随触摸位置,不拦截事件) */
.joystick-area {
  position: absolute;
  z-index: 20;
  pointer-events: none;
  transform: translate(-50%, -50%);
}

.joystick-base {
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%,
    rgba(244,162,97,0.25) 0%,
    rgba(244,162,97,0.08) 60%,
    rgba(244,162,97,0.02) 100%
  );
  border: 3rpx solid rgba(244,162,97,0.5);
  position: relative;
  box-shadow:
    inset 0 0 24rpx rgba(0,0,0,0.3),
    0 0 16rpx rgba(244,162,97,0.1);
}

.joystick-stick {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 30%,
    rgba(244,162,97,0.95) 0%,
    rgba(244,162,97,0.7) 100%
  );
  border: 3rpx solid #f4a261;
  position: absolute;
  left: 50%;
  top: 50%;
  margin-left: -22rpx;
  margin-top: -22rpx;
  transition: none;
  box-shadow:
    0 2rpx 6rpx rgba(0,0,0,0.4),
    inset 0 2rpx 3rpx rgba(255,255,255,0.2);
}

/* 返回键(需响应触摸) */
.back-float {
  position: absolute;
  top: calc(8rpx + var(--status-bar-height, 44px));
  left: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(15,15,26,0.75);
  border: 2rpx solid #f4a261;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 30;
  box-shadow:
    3rpx 0 0 0 #f4a261,
    -3rpx 0 0 0 #f4a261,
    0 3rpx 0 0 #f4a261,
    0 -3rpx 0 0 #f4a261,
    3rpx 3rpx 0 0 #f4a261,
    -3rpx 3rpx 0 0 #f4a261,
    3rpx -3rpx 0 0 #f4a261,
    -3rpx -3rpx 0 0 #f4a261;
}

.back-float:active {
  background: rgba(244,162,97,0.2);
}

.back-arrow {
  width: 24rpx;
  height: 24rpx;
  position: relative;
}

.arrow-left {
  width: 0;
  height: 0;
  border-top: 12rpx solid transparent;
  border-bottom: 12rpx solid transparent;
  border-right: 16rpx solid #f4a261;
  position: absolute;
  left: 4rpx;
  top: 0;
}

.arrow-left::before {
  content: '';
  position: absolute;
  right: -22rpx;
  top: -12rpx;
  width: 8rpx;
  height: 24rpx;
  background: #f4a261;
}

/* 坐标显示(左下角) */
.coord-display {
  position: absolute;
  bottom: calc(8rpx + env(safe-area-inset-bottom));
  left: 16rpx;
  z-index: 10;
  pointer-events: none;
}

.coord-text {
  font-size: 18rpx;
  color: rgba(244,162,97,0.6);
  font-family: monospace;
  letter-spacing: 1rpx;
}

/* 计数器 */
.counter {
  position: absolute;
  top: 30rpx;
  right: 100rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 10rpx;
  background: rgba(15, 15, 26, 0.85);
  border: 1rpx solid #f4a261;
  border-radius: 6rpx;
  z-index: 90;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
}

.counter-label {
  font-size: 14rpx;
  color: rgba(244, 162, 97, 0.7);
  font-weight: 500;
}

.counter-value {
  font-size: 16rpx;
  color: #f4a261;
  font-weight: 600;
  font-family: monospace;
  letter-spacing: 1rpx;
}

/* 设置按钮 */
.settings-btn {
  position: absolute;
  top: 60rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(192, 192, 192, 0.2);
  border: 2rpx solid rgba(200, 200, 200, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.settings-btn:active {
  transform: scale(0.95);
}

.gear-container {
  width: 24rpx;
  height: 24rpx;
  position: relative;
  animation: gearSpin 5s linear infinite;
}

.gear {
  width: 100%;
  height: 100%;
  position: relative;
}

.tooth {
  width: 6rpx;
  height: 10rpx;
  background: linear-gradient(180deg, #ffffff 0%, #c0c0c0 30%, #808080 70%, #606060 100%);
  position: absolute;
  top: 50%;
  left: 50%;
  transform-origin: center 17rpx;
  border-radius: 1rpx;
  box-shadow: 1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3), inset 1rpx 1rpx 1rpx rgba(255, 255, 255, 0.5);
}

.tooth.t1 { transform: translate(-50%, -17rpx) rotate(0deg); }
.tooth.t2 { transform: translate(-50%, -17rpx) rotate(45deg); }
.tooth.t3 { transform: translate(-50%, -17rpx) rotate(90deg); }
.tooth.t4 { transform: translate(-50%, -17rpx) rotate(135deg); }
.tooth.t5 { transform: translate(-50%, -17rpx) rotate(180deg); }
.tooth.t6 { transform: translate(-50%, -17rpx) rotate(225deg); }
.tooth.t7 { transform: translate(-50%, -17rpx) rotate(270deg); }
.tooth.t8 { transform: translate(-50%, -17rpx) rotate(315deg); }

.gear-body {
  width: 18rpx;
  height: 18rpx;
  background: linear-gradient(135deg, #ffffff 0%, #e0e0e0 30%, #a0a0a0 70%, #808080 100%);
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-shadow: inset 2rpx 2rpx 3rpx rgba(255, 255, 255, 0.8), inset -2rpx -2rpx 3rpx rgba(0, 0, 0, 0.2);
}

.center-hole {
  width: 6rpx;
  height: 6rpx;
  background: #0f0f1a;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1rpx solid rgba(180, 180, 180, 0.8);
}

@keyframes gearSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 背包按钮 */
.backpack-btn {
  position: absolute;
  top: 120rpx;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(139, 195, 74, 0.2);
  border: 2rpx solid rgba(139, 195, 74, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.backpack-btn:active {
  transform: scale(0.95);
}

.backpack-icon {
  width: 22rpx;
  height: 22rpx;
  position: relative;
}

.backpack-body {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #8bc34a 0%, #689f38 100%);
  border-radius: 4rpx 4rpx 8rpx 8rpx;
  position: relative;
  box-shadow: inset 2rpx 2rpx 4rpx rgba(255, 255, 255, 0.3), inset -2rpx -2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.backpack-body::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 14rpx;
  height: 3rpx;
  background: rgba(0, 0, 0, 0.2);
  border-radius: 2rpx;
}

.backpack-strap {
  position: absolute;
  top: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 4rpx;
  height: 8rpx;
  background: linear-gradient(180deg, #5d4037 0%, #4e342e 100%);
  border-radius: 2rpx 2rpx 0 0;
}