<view class="settings-page">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon">
        <view class="arrow"></view>
      </view>
    </view>
    <text class="nav-title">设置</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 设置内容 -->
  <view class="settings-content">
    <!-- 音效设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="speaker-icon">
            <view class="speaker"></view>
            <view class="sound-wave">
              <view class="wave wave1"></view>
              <view class="wave wave2"></view>
              <view class="wave wave3"></view>
            </view>
          </view>
        </view>
        <text class="section-text">音效设置</text>
      </view>

      <!-- 开始页面音乐开关 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="label-text">开始页面音乐</text>
        </view>
        <switch 
          class="item-switch" 
          color="#f4a261" 
          checked="{{startMusicEnabled}}" 
          bindchange="toggleStartMusic" 
        />
      </view>

      <!-- 地图页面音乐开关 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="label-text">地图页面音乐</text>
        </view>
        <switch 
          class="item-switch" 
          color="#f4a261" 
          checked="{{mapMusicEnabled}}" 
          bindchange="toggleMapMusic" 
        />
      </view>

      <!-- 音量调节 -->
      <view class="setting-item volume-item">
        <view class="item-label">
          <view class="volume-icon">
            <view class="volume-box">
              <view class="volume-bar bar1"></view>
              <view class="volume-bar bar2"></view>
              <view class="volume-bar bar3"></view>
            </view>
          </view>
          <text class="label-text">音量</text>
        </view>
        <view class="volume-control">
            <text class="volume-label volume-min">0</text>
            <slider 
              class="volume-slider" 
              activeColor="#f4a261" 
              backgroundColor="rgba(244, 162, 97, 0.2)" 
              block-size="24" 
              value="{{volume}}" 
              bindchange="onVolumeChange" 
            />
            <text class="volume-label volume-max">100</text>
            <text class="volume-value">{{volume}}%</text>
          </view>
      </view>
    </view>

    <!-- 日夜设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="time-icon">
            <view class="sun"></view>
            <view class="moon"></view>
          </view>
        </view>
        <text class="section-text">日夜设置</text>
      </view>

      <!-- 日夜切换 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="label-text">{{isDay ? '白天' : '晚上'}}</text>
        </view>
        <switch 
          class="item-switch" 
          color="#f4a261" 
          checked="{{isDay}}" 
          bindchange="toggleDayNight" 
        />
      </view>
    </view>

    <!-- 季节设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="season-icon">
            <view class="season-leaf"></view>
          </view>
        </view>
        <text class="section-text">季节设置</text>
      </view>

      <!-- 季节选择器 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="season-label">
            {{season === 'spring' ? '春季' : season === 'summer' ? '夏季' : season === 'autumn' ? '秋季' : '冬季'}}
          </text>
        </view>
        <view class="picker-btn" bindtap="showSeasonPicker">
          <text class="picker-text">选择季节</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

    </view>

  </view>

  <!-- 自定义季节选择弹窗 -->
  <view class="season-picker-modal" wx:if="{{showSeasonModal}}" bindtap="hideSeasonPicker">
    <view class="modal-mask" bindtap="hideSeasonPicker"></view>
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-title">
        <text class="title-text">选择季节</text>
      </view>
      <view class="season-grid">
        <view class="season-item spring" bindtap="selectSeason" data-season="spring">
          <text class="season-emoji">🌸</text>
          <text class="season-name">春季</text>
        </view>
        <view class="season-item summer" bindtap="selectSeason" data-season="summer">
          <text class="season-emoji">☀️</text>
          <text class="season-name">夏季</text>
        </view>
        <view class="season-item autumn" bindtap="selectSeason" data-season="autumn">
          <text class="season-emoji">🍂</text>
          <text class="season-name">秋季</text>
        </view>
        <view class="season-item winter" bindtap="selectSeason" data-season="winter">
          <text class="season-emoji">❄️</text>
          <text class="season-name">冬季</text>
        </view>
      </view>
    </view>
  </view>
</view>