<view class="settings-page">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="back-btn" bindtap="goBack">
      <view class="back-icon">
        <view class="arrow"></view>
      </view>
    </view>
    <text class="nav-title">设置</text>
    <view class="nav-placeholder"></view>
  </view>

  <!-- 设置内容 -->
  <view class="settings-content">
    <!-- 音效设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="speaker-icon">
            <view class="speaker"></view>
            <view class="sound-wave">
              <view class="wave wave1"></view>
              <view class="wave wave2"></view>
              <view class="wave wave3"></view>
            </view>
          </view>
        </view>
        <text class="section-text">音效设置</text>
      </view>

      <!-- 开始页面音乐开关 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="label-text">开始页面音乐</text>
        </view>
        <switch 
          class="item-switch" 
          color="#f4a261" 
          checked="{{startMusicEnabled}}" 
          bindchange="toggleStartMusic" 
        />
      </view>

      <!-- 地图页面音乐开关 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="label-text">地图页面音乐</text>
        </view>
        <switch 
          class="item-switch" 
          color="#f4a261" 
          checked="{{mapMusicEnabled}}" 
          bindchange="toggleMapMusic" 
        />
      </view>

      <!-- 音量调节 -->
      <view class="setting-item volume-item">
        <view class="item-label">
          <view class="volume-icon">
            <view class="volume-box">
              <view class="volume-bar bar1"></view>
              <view class="volume-bar bar2"></view>
              <view class="volume-bar bar3"></view>
            </view>
          </view>
          <text class="label-text">音量</text>
        </view>
        <view class="volume-control">
            <text class="volume-label volume-min">0</text>
            <slider 
              class="volume-slider" 
              activeColor="#f4a261" 
              backgroundColor="rgba(244, 162, 97, 0.2)" 
              block-size="24" 
              value="{{volume}}" 
              bindchange="onVolumeChange" 
            />
            <text class="volume-label volume-max">100</text>
            <text class="volume-value">{{volume}}%</text>
          </view>
      </view>
    </view>

    <!-- 日夜设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="time-icon">
            <view class="sun"></view>
            <view class="moon"></view>
          </view>
        </view>
        <text class="section-text">日夜设置</text>
      </view>

      <!-- 日夜切换 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="label-text">{{isDay ? '白天' : '晚上'}}</text>
        </view>
        <switch 
          class="item-switch" 
          color="#f4a261" 
          checked="{{isDay}}" 
          bindchange="toggleDayNight" 
        />
      </view>
    </view>

    <!-- 季节设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="season-icon">
            <view class="season-leaf"></view>
          </view>
        </view>
        <text class="section-text">季节设置</text>
      </view>

      <!-- 季节选择器 -->
      <view class="setting-item">
        <view class="item-label">
          <text class="season-label">
            {{season === 'spring' ? '春季' : season === 'summer' ? '夏季' : season === 'autumn' ? '秋季' : '冬季'}}
          </text>
        </view>
        <view class="picker-btn" bindtap="toggleSeasonSelector">
          <text class="picker-text">选择季节</text>
          <text class="picker-arrow">›</text>
        </view>
      </view>

      <!-- 下拉式季节选择器 -->
      <view class="season-selector" wx:if="{{showSeasonSelector}}">
        <view class="selector-option" bindtap="setSeason" data-season="spring">
          <text class="option-text">🌸 春季</text>
        </view>
        <view class="selector-option" bindtap="setSeason" data-season="summer">
          <text class="option-text">☀️ 夏季</text>
        </view>
        <view class="selector-option" bindtap="setSeason" data-season="autumn">
          <text class="option-text">🍂 秋季</text>
        </view>
        <view class="selector-option" bindtap="setSeason" data-season="winter">
          <text class="option-text">❄️ 冬季</text>
        </view>
      </view>

    </view>

    <!-- 其他设置区域 -->
    <view class="settings-section">
      <view class="section-title">
        <view class="section-icon">
          <view class="other-icon">
            <view class="other-dot"></view>
            <view class="other-dot"></view>
            <view class="other-dot"></view>
          </view>
        </view>
        <text class="section-text">其他</text>
      </view>

      <!-- 隐私政策 -->
      <view class="setting-item link-item" bindtap="openPrivacy">
        <view class="item-label">
          <text class="label-text">用户隐私保护指引</text>
        </view>
        <text class="link-arrow">›</text>
      </view>

      <!-- 客服入口 -->
      <view class="setting-item link-item">
        <view class="item-label">
          <text class="label-text">联系客服</text>
        </view>
        <button class="contact-btn" open-type="contact" session-from="settings">
          <text class="link-arrow">›</text>
        </button>
      </view>

    </view>

  </view>
</view>