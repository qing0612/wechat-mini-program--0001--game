@import '../../styles/pixel-theme.wxss';

.start-page {
  width: 100vw;
  height: 100vh;
  background: #0f0f1a;
  position: relative;
  overflow: hidden;
}

/* 全屏背景图 */
.bg-panel {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

.bg-image {
  width: 100%;
  height: 100%;
}

.bg-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background:
    repeating-linear-gradient(
      0deg, transparent 0, transparent 48rpx,
      rgba(244,162,97,0.03) 48rpx, rgba(244,162,97,0.03) 50rpx
    ),
    repeating-linear-gradient(
      90deg, transparent 0, transparent 48rpx,
      rgba(244,162,97,0.03) 48rpx, rgba(244,162,97,0.03) 50rpx
    ),
    linear-gradient(135deg, #0f0f1a 0%, #1a1a2e 50%, #2a2a4a 100%);
}

.placeholder-icon {
  width: 80rpx;
  height: 80rpx;
  border: 3rpx dashed #f4a261;
  position: relative;
  margin-bottom: 16rpx;
}

.placeholder-icon::before {
  content: '';
  position: absolute;
  width: 28rpx;
  height: 3rpx;
  background: #f4a261;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.placeholder-icon::after {
  content: '';
  position: absolute;
  width: 3rpx;
  height: 28rpx;
  background: #f4a261;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}

.placeholder-text {
  font-size: 28rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 4rpx;
}

.placeholder-sub {
  font-size: 18rpx;
  color: #666;
  margin-top: 10rpx;
}

/* 叠加信息层 */
.info-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(15,15,26,0.45);
}

.title-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.title-cn {
  font-size: 52rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 8rpx;
  text-shadow: 2rpx 2rpx 0 #0f0f1a;
}

.title-en {
  font-size: 16rpx;
  color: #ccc;
  letter-spacing: 4rpx;
  margin-top: 10rpx;
  text-transform: uppercase;
}

.subtitle-area {
  margin-bottom: 40rpx;
}

.subtitle {
  font-size: 22rpx;
  color: #aaa;
  letter-spacing: 8rpx;
}

.enter-btn {
  width: 320rpx;
  height: 76rpx;
  background: #f4a261;
  border: 3rpx solid #0f0f1a;
  box-shadow:
    5rpx 5rpx 0 0 #0f0f1a,
    inset 0 3rpx 0 0 rgba(255,255,255,0.3),
    inset 0 -3rpx 0 0 rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.enter-btn:active {
  transform: translate(2rpx, 2rpx);
  box-shadow: 3rpx 3rpx 0 0 #0f0f1a;
  background: #c47820;
}

.btn-text {
  font-size: 28rpx;
  color: #0f0f1a;
  font-weight: 900;
  letter-spacing: 8rpx;
}

.footer {
  margin-top: 24rpx;
}

.footer-text {
  font-size: 16rpx;
  color: #999;
  letter-spacing: 3rpx;
}

/* 设置按钮（缩小一半） */
.settings-btn {
  position: absolute;
  top: 60rpx;
  right: 40rpx;
  width: 40rpx;   /* 从80rpx缩小到40rpx */
  height: 40rpx;  /* 从80rpx缩小到40rpx */
  background: rgba(192, 192, 192, 0.15);
  border: 2rpx solid rgba(200, 200, 200, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.settings-btn:active {
  transform: scale(0.95);
}

/* 齿轮容器（缩小一半） */
.gear-container {
  width: 24rpx;   /* 从48rpx缩小到24rpx */
  height: 24rpx;  /* 从48rpx缩小到24rpx */
  position: relative;
  animation: spin 5s linear infinite;
}

.gear-container:hover {
  animation: spin 1.5s linear infinite;
}

/* 齿轮主体 */
.gear {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 齿轮齿（缩小一半） */
.tooth {
  width: 6rpx;    /* 从12rpx缩小到6rpx */
  height: 10rpx;  /* 从20rpx缩小到10rpx */
  background: linear-gradient(180deg, #ffffff 0%, #c0c0c0 30%, #808080 70%, #606060 100%);
  position: absolute;
  top: 50%;
  left: 50%;
  transform-origin: center 17rpx;  /* 从34rpx缩小到17rpx */
  border-radius: 1rpx;  /* 从2rpx缩小到1rpx */
  box-shadow: 
    1rpx 1rpx 2rpx rgba(0, 0, 0, 0.3),
    inset 1rpx 1rpx 1rpx rgba(255, 255, 255, 0.5);
}

/* 8个齿轮齿 */
.tooth.t1 { transform: translate(-50%, -17rpx) rotate(0deg); }    /* 从-34rpx缩小到-17rpx */
.tooth.t2 { transform: translate(-50%, -17rpx) rotate(45deg); }
.tooth.t3 { transform: translate(-50%, -17rpx) rotate(90deg); }
.tooth.t4 { transform: translate(-50%, -17rpx) rotate(135deg); }
.tooth.t5 { transform: translate(-50%, -17rpx) rotate(180deg); }
.tooth.t6 { transform: translate(-50%, -17rpx) rotate(225deg); }
.tooth.t7 { transform: translate(-50%, -17rpx) rotate(270deg); }
.tooth.t8 { transform: translate(-50%, -17rpx) rotate(315deg); }

/* 齿轮内圈（缩小一半） */
.gear-body {
  width: 18rpx;   /* 从36rpx缩小到18rpx */
  height: 18rpx;  /* 从36rpx缩小到18rpx */
  background: linear-gradient(135deg, #ffffff 0%, #e0e0e0 30%, #a0a0a0 70%, #808080 100%);
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 
    inset 2rpx 2rpx 3rpx rgba(255, 255, 255, 0.8),
    inset -2rpx -2rpx 3rpx rgba(0, 0, 0, 0.2),
    0 1rpx 2rpx rgba(0, 0, 0, 0.2);
}

/* 中心孔（缩小一半） */
.center-hole {
  width: 6rpx;    /* 从12rpx缩小到6rpx */
  height: 6rpx;   /* 从12rpx缩小到6rpx */
  background: #0f0f1a;
  border-radius: 50%;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  border: 1rpx solid rgba(180, 180, 180, 0.8);  /* 从2rpx缩小到1rpx */
}

/* 旋转动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 进入游戏进度条遮罩 */
.progress-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease-out;
}

.progress-title {
  font-size: 32rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 8rpx;
  margin-bottom: 30rpx;
  text-shadow: 2rpx 2rpx 0 #0f0f1a;
}

.progress-bar-wrap {
  width: 60%;
  height: 24rpx;
  background: #1a1a2e;
  border: 3rpx solid #f4a261;
  box-shadow: 3rpx 3rpx 0 0 #0f0f1a;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #f4a261 0%, #e76f51 100%);
  transition: width 0.06s linear;
}

.progress-percent {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #ccc;
  letter-spacing: 4rpx;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}