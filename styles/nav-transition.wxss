/* styles/nav-transition.wxss
 * 像素风页面过渡遮罩 —— 用于低层级→高层级页面导航
 *
 * 使用方式：
 *   在页面 .wxss 顶部：@import '../../styles/nav-transition.wxss';
 *   在页面 .wxml 中：
 *     <view class="nav-transition" wx:if="{{navVisible}}">
 *       <view class="nav-title">{{navTitle}}</view>
 *       <view class="nav-bar-outer">
 *         <view class="nav-bar-inner" style="width:{{navProgress}}%;"></view>
 *       </view>
 *       <view class="nav-percent">{{navProgress}}%</view>
 *     </view>
 *
 * 设计要点：
 *   - z-index 极高，覆盖所有内容
 *   - 深色背景 + 橙色调进度条，与现有像素主题一致
 *   - 无侵入：页面只需要在 data 中暴露 navVisible / navProgress / navTitle
 */

.nav-transition {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.94);
  z-index: 9999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  animation: navFadeIn 0.3s ease-out;
}

.nav-transition::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 50% 40%, rgba(244,162,97,0.08) 0%, transparent 50%),
    repeating-linear-gradient(0deg, transparent 0, transparent 3px, rgba(244,162,97,0.02) 3px, rgba(244,162,97,0.02) 4px);
  pointer-events: none;
}

.nav-title {
  font-size: 32rpx;
  color: #f4a261;
  font-weight: 900;
  letter-spacing: 8rpx;
  margin-bottom: 30rpx;
  text-shadow: 2rpx 2rpx 0 #0f0f1a;
  font-family: monospace;
  position: relative;
  z-index: 1;
}

.nav-bar-outer {
  width: 60%;
  max-width: 500rpx;
  height: 22rpx;
  background: #1a1a2e;
  border: 3rpx solid #f4a261;
  box-shadow: 3rpx 3rpx 0 0 #0f0f1a;
  overflow: hidden;
  position: relative;
  padding: 2rpx;
  z-index: 1;
}

.nav-bar-inner {
  height: 100%;
  background: linear-gradient(90deg, #f4a261 0%, #e76f51 100%);
  transition: width 80ms linear;
  box-shadow: 0 0 10rpx rgba(244,162,97,0.6);
}

.nav-bar-inner::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.35) 0%, transparent 100%);
}

.nav-percent {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #ccc;
  letter-spacing: 4rpx;
  font-family: monospace;
  position: relative;
  z-index: 1;
}

@keyframes navFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}